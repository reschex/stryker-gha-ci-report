{
  "name": "stryker-gha-ci-report",
  "version": "1.0.0",
  "description": "Convert Stryker mutation testing JSON reports to GitHub Actions summary markdown",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stryker-gha-ci-report": "dist/cli.js"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "compile": "tsc -p ./ && tsc -p tsconfig.json",
    "lint": "eslint src test",
    "lint:fix": "eslint --fix src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "report": "node dist/cli.js"
  },
  "keywords": [
    "stryker",
    "mutation-testing",
    "github-actions",
    "ci",
    "report"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
}
